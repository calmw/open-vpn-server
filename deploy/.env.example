# 云服务器公网 IP 或域名（客户端连接地址）
OVPN_SERVER=your.server.public.ip

# OpenVPN 监听端口（UDP）
OVPN_PORT=1194

# 初始化 PKI 时 CA 证书的 Common Name（非服务器地址，保持默认即可）
OVPN_CN=OpenVPN-CA

# 客户端 VPN 网段（默认 192.168.255.0/24）
OVPN_SUBNET=192.168.255.0

# 是否启用「证书+密码」双重验证（0=仅证书，兼容 OpenVPN Connect；1=需 Tunnelblick/CLI）
OVPN_PASSWORD_AUTH=0
